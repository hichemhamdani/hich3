#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:191
msgid "What is Bordereau Generator?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:192
msgid "Bordereau Generator is a WooCommerce plugin that connects your store with 100+ Algerian shipping companies. It allows you to create shipping labels, track packages, and automate your delivery workflow."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:195
msgid "How do I install the plugin?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:196
msgid ""
"1. Upload the plugin files to /wp-content/plugins/\n"
"2. Activate the plugin through the Plugins menu in WordPress\n"
"3. Navigate to Bordereau Generator in your admin menu\n"
"4. Go to Settings > License to enter your license key"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:199
msgid "What are the system requirements?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:200
msgid "WordPress 5.0+, WooCommerce 4.0+, PHP 7.4+, and an active internet connection for API communication."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/DocsTab.jsx:219
#: src/admin/js/components/TutorialTab.jsx:203
msgid "Is this plugin free?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:204
msgid "No, Bordereau Generator is a paid plugin. Visit amineware.me to purchase a license or contact us via WhatsApp at +213783018210. If you obtained this plugin from another source, you have stolen 3 years of work and are not eligible for any support."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:207
msgid "How do I activate my license key?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:208
msgid "Go to Bordereau Generator > Settings > License tab, enter the license key you received after purchase, and click Activate."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:217
msgid "Which shipping companies are supported?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:218
msgid "We support 100+ providers including Yalidine, ZR Express, Maystro Delivery, Yalitec, Guepex, SpeedMail, EcoTrack, Noest, and many more."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:221
msgid "How do I add a new shipping provider?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:222
msgid ""
"1. Go to the Shipping Providers tab\n"
"2. Click on the provider card you want to enable\n"
"3. Enter your API credentials\n"
"4. Toggle the provider ON\n"
"5. Click Save Settings"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:225
msgid "Where do I get API credentials?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:226
msgid ""
"Login to your shipping provider dashboard:\n"
"• Yalidine: Développement > Tableau de bord\n"
"• ZR Express: API Rest > Jetons API\n"
"• Maystro: Contact their team directly\n"
"• Others: Check their dashboard or contact support"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/DocsTab.jsx:227
#: src/admin/js/components/TutorialTab.jsx:229
msgid "Can I use multiple providers at once?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:230
msgid "Yes! You can enable and configure multiple shipping providers simultaneously. Customers can choose their preferred provider at checkout based on their location."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:233
msgid "What does the Import button do?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:234
msgid "The Import button fetches shipping rates, cities, and pickup points from the provider and creates WooCommerce shipping zones automatically. This saves you from manually configuring each zone."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:239
msgid "Orders & Labels"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:243
msgid "How do I create a shipping label?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:244
msgid ""
"1. Go to WooCommerce > Orders\n"
"2. Open the order you want to ship\n"
"3. Find the Bordereau Generator metabox\n"
"4. Select your shipping provider\n"
"5. Verify customer details\n"
"6. Click Create Bordereau"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:247
msgid "How does tracking work?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:248
msgid ""
"There are 3 ways to get tracking updates:\n"
"1. Auto Update: Enable in Settings for periodic background updates\n"
"2. Webhooks: Configure for real-time updates from the provider\n"
"3. Manual: Click the Refresh button on the order page"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:251
msgid "What is COD (Cash on Delivery)?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:252
msgid "COD means the customer pays upon delivery. The shipping company collects the payment and transfers it to you (minus their commission). This is the most common payment method in Algeria."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:255
msgid "Can I print multiple labels at once?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:256
msgid "Yes! Use the bulk actions feature in WooCommerce Orders. Select multiple orders, choose \"Print Bordereaux\" from the bulk actions dropdown, and click Apply."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/DocsTab.jsx:237
#: src/admin/js/components/TutorialTab.jsx:261
msgid "Order Tracking Shortcodes"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/DocsTab.jsx:239
#: src/admin/js/components/TutorialTab.jsx:265
msgid "How do I create a tracking page for customers?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:266
msgid "Create a new page in WordPress and add one of our tracking shortcodes. You can then add this page to your menu so customers can easily track their orders."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:269
msgid "What is the [bordreau_tracking] shortcode?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:270
msgid ""
"This shortcode creates a tracking form where customers enter their Order ID and Phone Number to track their order. Add it to any page:\n"
"\n"
"[bordreau_tracking]\n"
"\n"
"Customers will need their order number (e.g., #1234) and the billing phone number."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:273
msgid "What is the [bordreau_tracking_by_tracking_number] shortcode?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:274
msgid ""
"This shortcode creates a simpler tracking form where customers only need the shipping tracking number:\n"
"\n"
"[bordreau_tracking_by_tracking_number]\n"
"\n"
"This is useful when you send customers the tracking number directly."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/DocsTab.jsx:297
#: src/admin/js/components/TutorialTab.jsx:277
msgid "Can I customize the shortcode tag?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:278
msgid ""
"Yes! Use WordPress filters to change the shortcode tag:\n"
"\n"
"add_filter('bordreau_tracking_shortcode_tag', function() {\n"
"    return 'my_custom_tracking';\n"
"});"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:287
msgid "What is Auto Update and should I enable it?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:288
msgid "Auto Update automatically fetches tracking status updates from shipping providers in the background. Enable it if you want order statuses to update without manual intervention. Set the interval based on your order volume."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:291
msgid "What does Auto Insert Orders do?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:292
msgid "When enabled, orders are automatically sent to the shipping provider when they reach a specific status (e.g., Processing). This eliminates the need to manually create bordereaux for each order."
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:295
msgid "How do I customize the product string format?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:296
msgid ""
"Go to Settings > Advanced and modify the Product String Format. Available placeholders:\n"
"• {title} - Product name\n"
"• {qty} - Quantity\n"
"• {sku} - SKU code\n"
"• {attributes} - Product variations\n"
"• {id} - Product ID"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:299
msgid "What happens when I clear the cache?"
msgstr ""

#: admin/js/wc-bordereau-generator-admin.js:2
#: src/admin/js/components/TutorialTab.jsx:300
msgid ""
"Clearing cache removes stored cities, shipping rates, and provider responses. This is useful when:\n"
"• Provider updates their rates\n"
"• You see outdated information\n"
"• Troubleshooting issues\n"
"\n"
"You may need to re-import shipping rates after clearing."
msgstr ""

