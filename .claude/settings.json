{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"echo \\\"[$(date '+%Y-%m-%d %H:%M:%S')] [BASH] $CLAUDE_TOOL_INPUT_COMMAND\\\" >> .claude/logs/session.log 2>/dev/null || true\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"echo \\\"[$(date '+%Y-%m-%d %H:%M:%S')] [FILE_EDIT] $CLAUDE_TOOL_INPUT_FILE_PATH\\\" >> .claude/logs/session.log 2>/dev/null || true\""
          }
        ]
      }
    ]
  }
}
